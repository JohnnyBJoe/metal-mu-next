generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model system_concerts {
  id_c      Int      @id @default(autoincrement()) @db.UnsignedInt
  interpret Int
  datum     DateTime @db.Date
  misto     String   @db.VarChar(120)
  popis     String   @db.Text

  @@fulltext([misto], map: "misto")
  @@fulltext([popis], map: "popis")
}

model system_countries {
  id_c Int    @id @default(autoincrement()) @db.UnsignedInt
  text String @db.VarChar(100)
}

model system_discography {
  id_d      Int      @id @default(autoincrement()) @db.UnsignedInt
  interpret Int      @db.UnsignedInt
  name      String   @db.VarChar(150)
  type      Int      @db.TinyInt
  info      String   @db.Text
  vydano    String?  @db.VarChar(10)
  naposled  DateTime @db.Date
  obal      String   @db.VarChar(90)
  label     String   @db.Text
  date      DateTime @default(dbgenerated("('0000-00-00')")) @db.Date

  @@fulltext([label], map: "label")
  @@fulltext([name], map: "name")
}

model system_discography_recenze {
  id_r    Int      @id @default(autoincrement()) @db.UnsignedInt
  text    String   @db.Text
  author  String   @db.VarChar(50)
  napsano DateTime @db.Date
  album   Int      @db.UnsignedInt
}

model system_discography_tracks {
  id_t      Int    @id @default(autoincrement()) @db.UnsignedInt
  name      String @db.VarChar(255)
  album     Int    @db.UnsignedInt
  lyric     String @db.VarChar(200)
  mp3       String @db.VarChar(200)
  interpret Int    @db.UnsignedInt

  @@fulltext([mp3], map: "mp3")
  @@fulltext([name], map: "name")
}

model system_diskuze_prispevky {
  id_p    Int      @id @default(autoincrement()) @db.UnsignedInt
  jmeno   String   @db.VarChar(100)
  text    String   @db.Text
  date    DateTime @db.Date
  diskuze Int      @db.UnsignedInt
}

model system_diskuze_temata {
  id_d      Int      @id @default(autoincrement()) @db.UnsignedInt
  name      String   @db.VarChar(200)
  interpret Int      @db.UnsignedInt
  edit      DateTime @default(dbgenerated("('0000-00-00')")) @db.Date
}

model system_interprets {
  id_i       Int       @id @default(autoincrement()) @db.UnsignedInt
  name       String    @db.VarChar(250)
  styles     String    @db.VarChar(35)
  info       String    @db.Text
  foto       String    @db.VarChar(100)
  logo       String    @db.VarChar(100)
  city       String    @db.VarChar(40)
  date_start DateTime? @db.Date
  date_end   DateTime? @db.Date
  biografie  String    @db.Text
  country    Int       @db.UnsignedInt
  homepage   String    @db.VarChar(100)
  date       DateTime  @default(dbgenerated("('0000-00-00')")) @db.Date
  edit       DateTime  @default(dbgenerated("('0000-00-00')")) @db.Date

  @@fulltext([biografie], map: "biografie")
  @@fulltext([name], map: "name")
}

model system_interprets_members {
  id_m           Int      @id @default(autoincrement()) @db.UnsignedInt
  name           String   @db.VarChar(230)
  instrument     String   @db.VarChar(100)
  date_of_birth  DateTime @db.Date
  text           String   @db.Text
  interpret      Int
  place_of_birth String?  @db.VarChar(100)
  pusobeni       String?  @db.VarChar(200)
  date_of_dead   DateTime @default(dbgenerated("('0000-00-00')")) @db.Date
  stav           Bytes    @default(dbgenerated("('0')")) @db.Binary(1)

  @@fulltext([name], map: "name")
  @@fulltext([text], map: "text")
}

model system_links {
  id_l      Int    @id @default(autoincrement()) @db.UnsignedInt
  url       String @db.VarChar(200)
  type      Int    @db.SmallInt
  schvaleno Bytes  @db.Binary(1)
}

model system_pressgraphy {
  id_p      Int      @id @default(autoincrement()) @db.UnsignedInt
  text      String   @db.Text
  interpret Int      @db.UnsignedInt
  update    DateTime @db.Date
}

model system_styles {
  id_s Int    @id @default(autoincrement()) @db.UnsignedInt
  text String @db.VarChar(100)
}
