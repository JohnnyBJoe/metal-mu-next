generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Country {
  id   Int     @id @default(autoincrement())
  name String  @unique @db.VarChar(100)
  code String? @db.Char(2)

  bands Band[]

  @@map("countries")
}

model Style {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  bands BandStyle[]

  @@map("styles")
}

model Band {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(250)
  sortName String @db.VarChar(250)

  city String? @db.VarChar(100)

  formedYear  Int?
  formedMonth Int?
  formedDay   Int?

  endedYear  Int?
  endedMonth Int?
  endedDay   Int?

  homepage  String? @db.VarChar(255)
  biography String  @db.LongText

  countryId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country Country @relation(fields: [countryId], references: [id])

  styles  BandStyle[]
  members BandMember[]

  @@index([name])
  @@index([sortName])
  @@map("bands")
}

model BandStyle {
  bandId  Int
  styleId Int

  band  Band  @relation(fields: [bandId], references: [id], onDelete: Cascade)
  style Style @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@id([bandId, styleId])
  @@map("band_styles")
}

model Instrument {
  id   Int    @id @default(autoincrement())
  name String @unique @db.VarChar(100)

  members BandMember[]

  @@map("instruments")
}

model Member {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(200)

  birthYear  Int?
  birthMonth Int?
  birthDay   Int?

  deathYear  Int?
  deathMonth Int?
  deathDay   Int?

  biography String? @db.LongText

  bands BandMember[]

  @@index([name])
  @@map("members")
}

model BandMember {
  id Int @id @default(autoincrement())

  bandId       Int
  memberId     Int
  instrumentId Int

  joinedYear  Int?
  joinedMonth Int?
  joinedDay   Int?

  leftYear  Int?
  leftMonth Int?
  leftDay   Int?

  current Boolean @default(true)

  displayOrder Int @default(0)

  band       Band       @relation(fields: [bandId], references: [id], onDelete: Cascade)
  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Restrict)

  @@index([bandId])
  @@index([memberId])
  @@map("band_members")
}
